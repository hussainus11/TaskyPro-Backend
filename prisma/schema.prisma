// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DashboardVisibility {
  PRIVATE
  COMPANY
  ROLES
  USERS
}

model Company {
  id                       Int                     @id @default(autoincrement())
  name                     String
  email                    String                  @unique
  phone                    String?
  address                  String?
  website                  String?
  industry                 String?
  slug                     String                  @unique
  plan                     Plan                    @default(Free)
  subscriptionStatus       SubscriptionStatus      @default(Active)
  subscriptionStartDate    DateTime?
  subscriptionEndDate      DateTime?
  trialEndDate             DateTime?
  billingCycle             BillingCycle?           @default(Monthly)
  customFieldsSectionTitle String?                 @default("Custom Fields")
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  branches                 Branch[]
  users                    User[]
  sections                 FormSection[]
  activities               Activity[]              @relation("CompanyActivities")
  comments                 Comment[]               @relation("CompanyComments")
  messages                 Message[]
  leadStages               LeadStage[]
  documentStages           DocumentStage[]
  invoiceStages            InvoiceStage[]
  estimateStages           EstimateStage[]
  sources                  Source[]
  contactTypes             ContactType[]
  salutations              Salutation[]
  callStatuses             CallStatus[]
  companyTypes             CompanyType[]
  employees                Employee[]
  industries               Industry[]
  dealTypes                DealType[]
  currencies               Currency[]
  locations                Location[]
  taxes                    Tax[]
  unitsOfMeasurement       UnitOfMeasurement[]
  productProperties        ProductProperty[]
  dealPipelines            DealPipeline[]
  roles                    Role[]
  accessControls           AccessControl[]
  securities               Security[]
  permissionSettings       PermissionSetting[]
  businessProcesses        BusinessProcess[]
  emailTemplates           EmailTemplate[]
  smtpSettings             SmtpSetting[]
  emailNotifications       EmailNotification[]
  emailSignatures          EmailSignature[]
  formTemplates            FormTemplate[]
  entityData               EntityData[]
  customEntityPages        CustomEntityPage[]
  feedPosts                FeedPost[]              @relation("FeedPosts")
  notifications            Notification[]          @relation("Notifications")
  collabs                  Collab[]                @relation("Collabs")
  workGroups               WorkGroup[]             @relation("WorkGroups")
  documents                Document[]              @relation("Documents")
  calendarEvents           CalendarEvent[]         @relation("CalendarEvents")
  fitnessActivities        FitnessActivity[]       @relation("FitnessActivities")
  nutritionEntries         NutritionEntry[]        @relation("NutritionEntries")
  sleepRecords             SleepRecord[]           @relation("SleepRecords")
  products                 Product[]               @relation("Products")
  productCategories        ProductCategory[]       @relation("ProductCategories")
  productSubCategories     ProductSubCategory[]    @relation("ProductSubCategories")
  customers                Customer[]              @relation("Customers")
  orders                   Order[]                 @relation("Orders")
  folders                  Folder[]                @relation("Folders")
  files                    File[]                  @relation("Files")
  projects                 Project[]               @relation("Projects")
  menuItems                MenuItem[]
  chats                    Chat[]                  @relation("Chats")
  formSectionPermissions   FormSectionPermission[] @relation("FormSectionPermissions")
  formFieldPermissions     FormFieldPermission[]   @relation("FormFieldPermissions")
  mails                    Mail[]                  @relation("CompanyMails")
  chatAccess               ChatAccess[]
  customFields             CustomField[]
  analyticalReports        AnalyticalReport[]
  autoNumberings           AutoNumbering[]
  reminders                Reminder[]
  customerPayments         CustomerPayment[] @relation("CustomerPayments")
  supplierPayments         SupplierPayment[] @relation("SupplierPayments")
  suppliers                Supplier[]       @relation("Suppliers")
  orderReturns             OrderReturn[]    @relation("OrderReturns")
  tableCategories          TableCategory[]  @relation("TableCategories")
  tables                   Table[]          @relation("Tables")
  reportTemplates          ReportTemplate[] @relation("ReportTemplates")
  pdfReports               PdfReport[]      @relation("PdfReports")
  dealDashboards           DealDashboard[]
  loginHistory              LoginHistory[]
  storageQuotas            StorageQuota[]
  systemSettings           SystemSetting[]
  exceptionLogs            ExceptionLog[]
}

model Branch {
  id                       Int                     @id @default(autoincrement())
  name                     String
  address                  String?
  phone                    String?
  email                    String?
  companyId                Int
  customFieldsSectionTitle String?                 @default("Custom Fields")
  company                  Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  users                    User[]
  leadStages               LeadStage[]
  documentStages           DocumentStage[]
  invoiceStages            InvoiceStage[]
  estimateStages           EstimateStage[]
  sources                  Source[]
  contactTypes             ContactType[]
  salutations              Salutation[]
  callStatuses             CallStatus[]
  companyTypes             CompanyType[]
  employees                Employee[]
  industries               Industry[]
  dealTypes                DealType[]
  currencies               Currency[]
  locations                Location[]
  taxes                    Tax[]
  unitsOfMeasurement       UnitOfMeasurement[]
  productProperties        ProductProperty[]
  dealPipelines            DealPipeline[]
  roles                    Role[]
  accessControls           AccessControl[]
  securities               Security[]
  permissionSettings       PermissionSetting[]
  businessProcesses        BusinessProcess[]
  formSectionPermissions   FormSectionPermission[] @relation("FormSectionPermissions")
  formFieldPermissions     FormFieldPermission[]   @relation("FormFieldPermissions")
  emailTemplates           EmailTemplate[]
  smtpSettings             SmtpSetting[]
  emailNotifications       EmailNotification[]
  emailSignatures          EmailSignature[]
  formTemplates            FormTemplate[]
  entityData               EntityData[]
  customEntityPages        CustomEntityPage[]
  feedPosts                FeedPost[]              @relation("FeedPosts")
  notifications            Notification[]          @relation("Notifications")
  collabs                  Collab[]                @relation("Collabs")
  workGroups               WorkGroup[]             @relation("WorkGroups")
  documents                Document[]              @relation("Documents")
  calendarEvents           CalendarEvent[]         @relation("CalendarEvents")
  fitnessActivities        FitnessActivity[]       @relation("FitnessActivities")
  nutritionEntries         NutritionEntry[]        @relation("NutritionEntries")
  sleepRecords             SleepRecord[]           @relation("SleepRecords")
  products                 Product[]               @relation("Products")
  productCategories        ProductCategory[]       @relation("ProductCategories")
  productSubCategories     ProductSubCategory[]    @relation("ProductSubCategories")
  customers                Customer[]              @relation("Customers")
  orders                   Order[]                 @relation("Orders")
  folders                  Folder[]                @relation("Folders")
  files                    File[]                  @relation("Files")
  branchActivities         Activity[]              @relation("BranchActivities")
  branchComments           Comment[]               @relation("BranchComments")
  projects                 Project[]               @relation("Projects")
  menuItems                MenuItem[]
  chats                    Chat[]                  @relation("Chats")
  mails                    Mail[]                  @relation("BranchMails")
  chatAccess               ChatAccess[]
  customFields             CustomField[]
  analyticalReports        AnalyticalReport[]
  autoNumberings           AutoNumbering[]
  reminders                Reminder[]
  customerPayments         CustomerPayment[] @relation("CustomerPayments")
  supplierPayments         SupplierPayment[] @relation("SupplierPayments")
  suppliers                Supplier[]       @relation("Suppliers")
  orderReturns             OrderReturn[]    @relation("OrderReturns")
  tableCategories          TableCategory[]  @relation("TableCategories")
  tables                   Table[]          @relation("Tables")
  reportTemplates          ReportTemplate[] @relation("ReportTemplates")
  pdfReports               PdfReport[]      @relation("PdfReports")
  dealDashboards           DealDashboard[]
  loginHistory              LoginHistory[]
  storageQuotas            StorageQuota[]
  systemSettings           SystemSetting[]
  exceptionLogs            ExceptionLog[]
}

model User {
  id                     Int                     @id @default(autoincrement())
  name                   String
  email                  String                  @unique
  password               String? // Hashed password
  googleId               String?                 @unique // Google OAuth ID
  mustChangePassword     Boolean                 @default(true) // Require password change on first login
  country                String
  role                   UserRole
  image                  String
  status                 Status
  plan_name              Plan
  phone                  String?
  location               String?
  department             String?
  companyId              Int?
  branchId               Int?
  roleId                 Int? // Custom user role (for RBAC)
  customRole             Role?                   @relation(fields: [roleId], references: [id], onDelete: SetNull)
  company                Company?                @relation(fields: [companyId], references: [id])
  branch                 Branch?                 @relation(fields: [branchId], references: [id])
  notes                  Note[]
  noteLabels             NoteLabel[]
  todos                  Todo[]
  settings               UserSettings?
  passwordResetTokens    PasswordResetToken[]
  emailSignatures        EmailSignature[]
  feedPosts              FeedPost[]              @relation("FeedPosts")
  feedLikes              FeedLike[]              @relation("FeedLikes")
  feedComments           FeedComment[]           @relation("FeedComments")
  notifications          Notification[]          @relation("Notifications")
  notificationActors     Notification[]          @relation("NotificationActors")
  createdCollabs         Collab[]                @relation("CreatedCollabs")
  collabMembers          CollabMember[]          @relation("CollabMembers")
  collabInvitations      CollabInvitation[]      @relation("CollabInvitations")
  createdWorkGroups      WorkGroup[]             @relation("CreatedWorkGroups")
  workGroupMembers       WorkGroupMember[]       @relation("WorkGroupMembers")
  createdDocuments       Document[]              @relation("CreatedDocuments")
  calendarEvents         CalendarEvent[]         @relation("CalendarEvents")
  managedProjects        Project[]               @relation("ManagedProjects")
  projectMembers         ProjectMember[]         @relation("ProjectMembers")
  reminders              Reminder[]              @relation("Reminders")
  fitnessActivities      FitnessActivity[]       @relation("FitnessActivities")
  nutritionEntries       NutritionEntry[]        @relation("NutritionEntries")
  sleepRecords           SleepRecord[]           @relation("SleepRecords")
  folders                Folder[]                @relation("Folders")
  files                  File[]                  @relation("Files")
  connectionsAsUser1     UserConnection[]        @relation("User1Connections")
  connectionsAsUser2     UserConnection[]        @relation("User2Connections")
  createdProducts        Product[]               @relation("CreatedProducts")
  updatedProducts        Product[]               @relation("UpdatedProducts")
  createdReportTemplates ReportTemplate[]        @relation("CreatedReportTemplates")
  updatedReportTemplates ReportTemplate[]        @relation("UpdatedReportTemplates")
  createdPdfReports      PdfReport[]             @relation("CreatedPdfReports")
  updatedPdfReports      PdfReport[]             @relation("UpdatedPdfReports")
  createdDealDashboards  DealDashboard[]         @relation("CreatedDealDashboards")
  dealDashboardUserShares DealDashboardUserShare[]
  dealDashboardPrefs     DealDashboardUserPref[]
  chatParticipants       ChatParticipant[]       @relation("ChatParticipants")
  chatMessages           ChatMessage[]           @relation("ChatMessages")
  formSectionPermissions FormSectionPermission[] @relation("FormSectionPermissions")
  formFieldPermissions   FormFieldPermission[]   @relation("FormFieldPermissions")
  mails                  Mail[]                  @relation("UserMails")
  chatAccessGranted      ChatAccess[]            @relation("ChatAccessGranted")
  chatAccessReceived     ChatAccess[]            @relation("ChatAccessReceived")
  loginHistory           LoginHistory[]
  exceptionLogs         ExceptionLog[]          @relation("ExceptionLogs")
  processedReturns      OrderReturn[]          @relation("ProcessedReturns")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model UserConnection {
  id        Int              @id @default(autoincrement())
  user1Id   Int // First user (initiator)
  user2Id   Int // Second user (recipient)
  user1     User             @relation("User1Connections", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User             @relation("User2Connections", fields: [user2Id], references: [id], onDelete: Cascade)
  status    ConnectionStatus @default(pending) // Connection status
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([user1Id, user2Id]) // Ensure unique connection between two users
  @@index([user1Id])
  @@index([user2Id])
  @@index([status])
}

enum ConnectionStatus {
  pending // Connection request pending approval
  connected // Connection accepted and active
  blocked // Connection blocked by one user
}

enum Status {
  active
  inactive
  pending
}

enum Plan {
  Free
  Basic
  Pro
  Enterprise
}

enum SubscriptionStatus {
  Active
  Inactive
  Cancelled
  Expired
  Pending
}

enum BillingCycle {
  Monthly
  Yearly
}

enum UserRole {
  admin
  manager
  employee
}

model Note {
  id             Int                 @id @default(autoincrement())
  title          String
  content        String?
  type           NoteType
  isArchived     Boolean             @default(false)
  image          String?
  userId         Int
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  labels         NoteLabel[]
  checklistItems NoteChecklistItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model NoteLabel {
  id        Int      @id @default(autoincrement())
  title     String
  color     String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NoteChecklistItem {
  id        Int      @id @default(autoincrement())
  text      String
  checked   Boolean  @default(false)
  noteId    Int
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum NoteType {
  text
  checklist
  image
}

enum FieldType {
  text
  email
  phone
  textarea
  select
  number
  url
  image
}

model FormSection {
  id          Int                     @id @default(autoincrement())
  title       String
  description String?
  order       Int                     @default(0)
  position    String?                 @default("center") // Position: left, right, top, bottom, center
  columns     Int?                    @default(12) // Number of columns out of 12 (1-12)
  companyId   Int?
  company     Company?                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isDefault   Boolean                 @default(false)
  fields      FormField[]
  permissions FormSectionPermission[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([companyId])
}

model FormField {
  id          Int                   @id @default(autoincrement())
  label       String
  type        FieldType
  value       String?
  options     String[]              @default([])
  required    Boolean               @default(false)
  order       Int                   @default(0)
  sectionId   Int
  section     FormSection           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  permissions FormFieldPermission[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([sectionId])
}

model FormSectionPermission {
  id        Int         @id @default(autoincrement())
  sectionId Int
  userId    Int
  companyId Int?
  branchId  Int?
  canView   Boolean     @default(true)
  section   FormSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user      User        @relation("FormSectionPermissions", fields: [userId], references: [id], onDelete: Cascade)
  company   Company?    @relation("FormSectionPermissions", fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?     @relation("FormSectionPermissions", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([sectionId, userId, companyId, branchId])
  @@index([sectionId])
  @@index([userId])
  @@index([companyId])
  @@index([branchId])
}

model FormFieldPermission {
  id        Int       @id @default(autoincrement())
  fieldId   Int
  userId    Int
  companyId Int?
  branchId  Int?
  canView   Boolean   @default(true)
  field     FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  user      User      @relation("FormFieldPermissions", fields: [userId], references: [id], onDelete: Cascade)
  company   Company?  @relation("FormFieldPermissions", fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?   @relation("FormFieldPermissions", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([fieldId, userId, companyId, branchId])
  @@index([fieldId])
  @@index([userId])
  @@index([companyId])
  @@index([branchId])
}

model Activity {
  id         Int      @id @default(autoincrement())
  type       String // Activity type (created, updated, status_changed, etc.)
  message    String
  entityType String? // Entity type (LEAD, DEAL, CONTACT, CUSTOM, etc.)
  entityId   Int? // ID of the entity
  userId     Int?
  companyId  Int?
  branchId   Int?
  company    Company? @relation("CompanyActivities", fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation("BranchActivities", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([entityType, entityId, companyId])
}

model Comment {
  id         Int      @id @default(autoincrement())
  text       String
  entityType String? // Entity type (LEAD, DEAL, CONTACT, CUSTOM, etc.)
  entityId   Int? // ID of the entity
  userId     Int?
  companyId  Int?
  branchId   Int?
  company    Company? @relation("CompanyComments", fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation("BranchComments", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([entityType, entityId, companyId])
}

model Message {
  id        Int      @id @default(autoincrement())
  text      String
  userId    Int?
  companyId Int?
  isSent    Boolean  @default(true)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([userId])
}

// Chat models for messaging functionality
model Chat {
  id            Int               @id @default(autoincrement())
  type          ChatType          @default(DIRECT) // DIRECT or GROUP
  name          String? // Group chat name (null for direct chats)
  companyId     Int?
  branchId      Int?
  company       Company?          @relation("Chats", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?           @relation("Chats", fields: [branchId], references: [id], onDelete: Cascade)
  participants  ChatParticipant[]
  messages      ChatMessage[]
  lastMessageId Int?
  lastMessage   ChatMessage?      @relation("LastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)
  isArchived    Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([isArchived])
}

model ChatParticipant {
  id         Int       @id @default(autoincrement())
  chatId     Int
  userId     Int
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User      @relation("ChatParticipants", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime? // Last time user read messages in this chat
  joinedAt   DateTime  @default(now())
  leftAt     DateTime? // When user left the chat (for group chats)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
}

model ChatMessage {
  id            Int           @id @default(autoincrement())
  chatId        Int
  senderId      Int
  chat          Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender        User          @relation("ChatMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content       String?       @db.Text // Text content (null for media messages)
  type          MessageType   @default(TEXT)
  data          Json? // Additional data for media messages (file path, images array, etc.)
  status        MessageStatus @default(SENT) // SENT, DELIVERED, READ
  replyToId     Int? // Reply to another message
  replyTo       ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies       ChatMessage[] @relation("MessageReplies")
  lastMessageIn Chat[]        @relation("LastMessage")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([chatId])
  @@index([senderId])
  @@index([status])
  @@index([createdAt])
}

enum ChatType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  SOUND
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model ChatAccess {
  id        Int      @id @default(autoincrement())
  userId    Int // User who grants access
  targetUserId Int // User who receives access (can chat with userId)
  user      User     @relation("ChatAccessGranted", fields: [userId], references: [id], onDelete: Cascade)
  targetUser User     @relation("ChatAccessReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  companyId Int?
  branchId  Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, targetUserId, companyId, branchId])
  @@index([userId])
  @@index([targetUserId])
  @@index([companyId])
  @@index([branchId])
  @@index([companyId, branchId])
}

enum TodoStatus {
  pending
  inProgress
  completed
}

enum TodoPriority {
  high
  medium
  low
}

model Todo {
  id           String        @id
  title        String
  description  String?
  status       TodoStatus    @default(pending)
  priority     TodoPriority  @default(medium)
  starred      Boolean       @default(false)
  dueDate      DateTime?
  reminderDate DateTime?
  position     Int           @default(0)
  userId       Int?
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo   String[]      @default([]) // Array of user IDs or emails
  comments     TodoComment[]
  files        TodoFile[]
  subTasks     TodoSubTask[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model TodoComment {
  id        String   @id
  text      String
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([todoId])
}

model TodoFile {
  id         String   @id
  name       String
  url        String
  type       String
  size       Int
  todoId     String
  todo       Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([todoId])
}

model TodoSubTask {
  id        String   @id
  title     String
  completed Boolean  @default(false)
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([todoId])
}

model UserSettings {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile settings
  username    String?
  bio         String?
  profileUrls String[] @default([])
  avatar      String?

  // Account settings
  dateOfBirth DateTime?
  language    String?   @default("en")

  // Billing settings
  billingPlan     String?
  nextPaymentDate DateTime?
  paymentMethods  Json? // Array of payment method objects

  // Appearance settings
  theme String? @default("light")
  font  String? @default("system")

  // Notification settings
  notificationType    String? @default("all")
  mobileNotifications Boolean @default(false)
  communicationEmails Boolean @default(false)
  socialEmails        Boolean @default(true)
  marketingEmails     Boolean @default(false)
  securityEmails      Boolean @default(true)

  // Display settings
  sidebarItems String[] @default([])

  // Table preferences (column visibility, sorting, etc. per table)
  tablePreferences Json? // Store column visibility preferences per table: { "companies": { "name": true, "email": false, ... } }

  // Skills
  skills String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

enum LeadStageType {
  initial
  additional
  success
  failed
}

enum DocumentStageType {
  initial
  additional
  success
  failed
}

model LeadStage {
  id        Int           @id @default(autoincrement())
  name      String
  color     String // Hex color value
  order     Int
  type      LeadStageType
  companyId Int?
  branchId  Int?
  company   Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([companyId, branchId])
}

