  QUOTE_ACCEPTED
  QUOTE_REJECTED
  USER_MENTIONED
  COMMENT_ADDED
  FILE_UPLOADED
  CUSTOM
}

enum NotificationFrequency {
  IMMEDIATE
  HOURLY_DIGEST
  DAILY_DIGEST
  WEEKLY_DIGEST
  NEVER
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
  PUSH
  ALL
}

model EmailNotification {
  id          Int                   @id @default(autoincrement())
  name        String // Notification name
  type        NotificationType // Type of notification
  description String? // Notification description
  trigger     Json? // Trigger conditions (JSON)
  recipients  Json? // Recipient configuration (JSON: users, roles, teams, etc.)
  templateId  Int? // Email template ID (optional)
  frequency   NotificationFrequency @default(IMMEDIATE) // How often to send
  channels    Json? // Notification channels (JSON array)
  conditions  Json? // Additional conditions (JSON)
  isActive    Boolean               @default(true) // Whether notification is active
  isSystem    Boolean               @default(false) // Whether this is a system notification
  companyId   Int?
  branchId    Int?
  company     Company?              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([name, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([isActive])
  @@index([frequency])
  @@index([companyId, branchId])
}

model EmailSignature {
  id        Int      @id @default(autoincrement())
  name      String // Signature name
  content   String   @db.Text // Signature HTML content
  plainText String?  @db.Text // Plain text version (optional)
  userId    Int? // User-specific signature (null for company-wide)
  isDefault Boolean  @default(false) // Whether this is the default signature
  isActive  Boolean  @default(true) // Whether signature is active
  companyId Int?
  branchId  Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, userId, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([isDefault])
  @@index([isActive])
  @@index([companyId, branchId])
  @@index([userId, companyId])
}

enum FormEntityType {
  LEAD
  DEAL
  CONTACT
  COMPANY
  USER
  TASK
  INVOICE
  QUOTE
  PRODUCT
  CUSTOMER
  CUSTOM
}

model FormTemplate {
  id               Int               @id @default(autoincrement())
  name             String // Template name
  description      String? // Template description
  entityType       FormEntityType // Type of entity this form creates
  customEntityName String? // Name of custom entity (required when entityType is CUSTOM)
  formFields       Json // Form field definitions (JSON array of field objects)
  workflowId       Int? // Associated workflow/business process
  workflow         BusinessProcess?  @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  path             String? // Route path where this form is accessible (e.g., "/dashboard/forms/lead-capture")
  isActive         Boolean           @default(true) // Whether template is active
  settings         Json? // Additional template settings (validation rules, styling, etc.)
  companyId        Int?
  branchId         Int?
  company          Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  entityData       EntityData[] // Entity data created from this template
  customEntityPage CustomEntityPage? // Custom entity page if this template is for a custom entity
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([name, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([entityType])
  @@index([isActive])
  @@index([workflowId])
  @@index([companyId, branchId])
  @@index([customEntityName])
}

model PricingPlan {
  id               Int      @id @default(autoincrement())
  name             String // Plan name (e.g., "Basic", "Pro", "Enterprise")
  description      String? // Plan description
  price            Float // Monthly price
  yearlyPrice      Float? // Yearly price (optional)
  industry         String? // Industry this plan is for (null = all industries)
  features         Json // Array of feature objects
  enabledMenuItems Json? // Array of menu item IDs/paths that are enabled for this plan
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([industry])
  @@index([isActive])
}

model CustomEntityPage {
  id               Int          @id @default(autoincrement())
  name             String // Display name (e.g., "Designation")
  slug             String // URL slug (e.g., "designation")
  templateId       Int          @unique // Reference to the FormTemplate that created this page
  template         FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  customEntityName String // Name of the custom entity
  icon             String? // Icon name for sidebar
  description      String? // Page description
  isActive         Boolean      @default(true)
  order            Int          @default(0) // Order in sidebar
  companyId        Int?
  branchId         Int?
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch?      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([slug, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([templateId])
  @@index([isActive])
}

model EntityData {
  id               Int            @id @default(autoincrement())
  entityType       FormEntityType // Type of entity (LEAD, DEAL, CONTACT, etc.)
  customEntityName String? // Name of custom entity if entityType is CUSTOM
  templateId       Int? // Form template ID that was used to create this entity
  template         FormTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  data             Json // Entity data (stored as JSON - contains all form field values)
  companyId        Int?
  branchId         Int?
  company          Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch?        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([entityType])
  @@index([entityType, companyId, branchId])
  @@index([templateId])
  @@index([customEntityName])
  @@index([createdAt])
}

model FeedPost {
  id            Int            @id @default(autoincrement())
  content       String         @db.Text
  image         String?
  userId        Int
  user          User           @relation("FeedPosts", fields: [userId], references: [id], onDelete: Cascade)
  companyId     Int?
  branchId      Int?
  company       Company?       @relation("FeedPosts", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation("FeedPosts", fields: [branchId], references: [id], onDelete: Cascade)
  likes         FeedLike[]
  comments      FeedComment[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([createdAt])
}

model FeedLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation("FeedLikes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model FeedComment {
  id        Int      @id @default(autoincrement())
  text      String   @db.Text
  postId    Int
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation("FeedComments", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
}

enum FeedNotificationType {
  POST_CREATED
  POST_LIKED
  POST_COMMENTED
  CALENDAR_EVENT_STARTING
}

model Notification {
  id        Int                  @id @default(autoincrement())
  type      FeedNotificationType
  title     String
  message   String               @db.Text
  isRead    Boolean              @default(false)
  userId    Int // User who receives the notification
  user      User                 @relation("Notifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId   Int? // User who triggered the notification (e.g., who liked/commented)
  actor     User?                @relation("NotificationActors", fields: [actorId], references: [id], onDelete: SetNull)
  postId    Int? // Related feed post
  post      FeedPost?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  companyId Int?
  branchId  Int?
  company   Company?             @relation("Notifications", fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?              @relation("Notifications", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([companyId])
  @@index([branchId])
  @@index([createdAt])
  @@index([userId, isRead])
}

enum CollabStatus {
  ACTIVE
  PENDING
  ARCHIVED
  COMPLETED
}

enum CollabMemberRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum CollabInvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model Collab {
  id          Int                @id @default(autoincrement())
  name        String
  description String?            @db.Text
  status      CollabStatus       @default(ACTIVE)
  createdById Int // User who created the collab
  createdBy   User               @relation("CreatedCollabs", fields: [createdById], references: [id], onDelete: Cascade)
  companyId   Int?
  branchId    Int?
  company     Company?           @relation("Collabs", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?            @relation("Collabs", fields: [branchId], references: [id], onDelete: Cascade)
  members     CollabMember[]
  invitations CollabInvitation[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([createdById])
  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
}

model CollabMember {
  id         Int              @id @default(autoincrement())
  collabId   Int
  collab     Collab           @relation(fields: [collabId], references: [id], onDelete: Cascade)
  userId     Int? // Internal user ID (if user exists in system)
  user       User?            @relation("CollabMembers", fields: [userId], references: [id], onDelete: SetNull)
  email      String // Email of the member (required for external members)
  name       String? // Name of the member
  role       CollabMemberRole @default(MEMBER)
  isExternal Boolean          @default(false) // True if member is not in the system
  joinedAt   DateTime         @default(now())
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([collabId, userId])
  @@unique([collabId, email])
  @@index([collabId])
  @@index([userId])
  @@index([email])
}

model CollabInvitation {
  id          Int                    @id @default(autoincrement())
  collabId    Int
  collab      Collab                 @relation(fields: [collabId], references: [id], onDelete: Cascade)
  email       String // Email to invite
  name        String? // Name of invitee
  role        CollabMemberRole       @default(MEMBER)
  status      CollabInvitationStatus @default(PENDING)
  invitedById Int // User who sent the invitation
  invitedBy   User                   @relation("CollabInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  token       String                 @unique // Unique token for invitation acceptance
  expiresAt   DateTime // Invitation expiration date
  acceptedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([collabId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@index([invitedById])
}

enum WorkGroupStatus {
  ACTIVE
  ARCHIVED
}

enum WorkGroupMemberRole {
  LEADER
  MEMBER
  VIEWER
}

model WorkGroup {
  id          Int               @id @default(autoincrement())
  name        String
  description String?           @db.Text
  status      WorkGroupStatus   @default(ACTIVE)
  createdById Int // User who created the work group
  createdBy   User              @relation("CreatedWorkGroups", fields: [createdById], references: [id], onDelete: Cascade)
  companyId   Int?
  branchId    Int?
  company     Company?          @relation("WorkGroups", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?           @relation("WorkGroups", fields: [branchId], references: [id], onDelete: Cascade)
  members     WorkGroupMember[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([createdById])
  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
}

model WorkGroupMember {
  id          Int                 @id @default(autoincrement())
  workGroupId Int
  workGroup   WorkGroup           @relation(fields: [workGroupId], references: [id], onDelete: Cascade)
  userId      Int // Internal user ID (required - only internal users)
  user        User                @relation("WorkGroupMembers", fields: [userId], references: [id], onDelete: Cascade)
  role        WorkGroupMemberRole @default(MEMBER)
  joinedAt    DateTime            @default(now())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([workGroupId, userId])
  @@index([workGroupId])
  @@index([userId])
}

enum DocumentType {
  DOCUMENT
  SPREADSHEET
  PRESENTATION
  BOARD
}

model Document {
  id          Int          @id @default(autoincrement())
  name        String
  type        DocumentType
  filePath    String? // Path to the stored file
  fileSize    Int? // File size in bytes
  mimeType    String? // MIME type of the file
  content     String?      @db.Text // Document content (HTML for documents, JSON for spreadsheets/presentations)
  createdById Int
  createdBy   User         @relation("CreatedDocuments", fields: [createdById], references: [id], onDelete: Cascade)
  companyId   Int?
  branchId    Int?
  company     Company?     @relation("Documents", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation("Documents", fields: [branchId], references: [id], onDelete: Cascade)
  isShared    Boolean      @default(false)
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([createdById])
  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([createdAt])
}

enum EventColor {
  sky
  amber
  violet
  rose
  emerald
  orange
}

model CalendarEvent {
  id          String      @id @default(uuid())
  title       String
  description String?
  start       DateTime
  end         DateTime
  allDay      Boolean     @default(false)
  color       EventColor? @default(sky)
  location    String?
  userId      Int?
  user        User?       @relation("CalendarEvents", fields: [userId], references: [id], onDelete: Cascade)
  companyId   Int?
  branchId    Int?
  company     Company?    @relation("CalendarEvents", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?     @relation("CalendarEvents", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([start])
  @@index([end])
  @@index([userId, start, end])
}

enum FitnessActivityType {
  RUNNING
  CYCLING
  WALKING
  SWIMMING
  STRENGTH_TRAINING
  YOGA
  PILATES
  CARDIO
  CROSSFIT
  OTHER
}

enum FitnessActivityStatus {
  PLANNED
  COMPLETED
  CANCELLED
  SKIPPED
}

model FitnessActivity {
  id          Int                   @id @default(autoincrement())
  title       String
  description String?
  type        FitnessActivityType
  status      FitnessActivityStatus @default(PLANNED)
  startTime   DateTime
  endTime     DateTime?
  duration    Int? // Duration in minutes
  distance    Float? // Distance in km
  calories    Int? // Calories burned
  heartRate   Int? // Average heart rate (BPM)
  notes       String?               @db.Text
  userId      Int
  user        User                  @relation("FitnessActivities", fields: [userId], references: [id], onDelete: Cascade)
  companyId   Int?
  branchId    Int?
  company     Company?              @relation("FitnessActivities", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?               @relation("FitnessActivities", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([type])
  @@index([status])
  @@index([startTime])
  @@index([userId, startTime])
}

model NutritionEntry {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("NutritionEntries", fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date // Date of the entry
  calories  Int // Total calories
  carbs     Float // Carbs in grams
  protein   Float // Protein in grams
  fats      Float // Fats in grams
  companyId Int?
  branchId  Int?
  company   Company? @relation("NutritionEntries", fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation("NutritionEntries", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([date])
  @@index([userId, date])
}

model SleepRecord {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation("SleepRecords", fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime  @db.Date // Date of the sleep record
  sleepHours   Float // Hours of sleep (e.g., 7.5)
  sleepMinutes Int // Additional minutes (e.g., 30)
  quality      Int // Sleep quality percentage (0-100)
  bedTime      DateTime? // When user went to bed
  wakeTime     DateTime? // When user woke up
  companyId    Int?
  branchId     Int?
  company      Company?  @relation("SleepRecords", fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch?   @relation("SleepRecords", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([date])
  @@index([userId, date])
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  FAILED
}

enum OrderType {
  SALE
  RETURN
  REFUND
}

model ProductCategory {
  id            Int                  @id @default(autoincrement())
  name          String
  description   String?
  isActive      Boolean              @default(true)
  companyId     Int?
  branchId      Int?
  company       Company?             @relation("ProductCategories", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?              @relation("ProductCategories", fields: [branchId], references: [id], onDelete: Cascade)
  subCategories ProductSubCategory[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([name, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([isActive])
  @@index([companyId, branchId])
}

model ProductSubCategory {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  categoryId  Int
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isActive    Boolean         @default(true)
  companyId   Int?
  branchId    Int?
  company     Company?        @relation("ProductSubCategories", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?         @relation("ProductSubCategories", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([name, categoryId, companyId, branchId])
  @@index([categoryId])
  @@index([companyId])
  @@index([branchId])
  @@index([isActive])
  @@index([companyId, branchId])
}

enum ProductType {
  SINGLE // Simple single product
  VARIANT // Product with variants (size, color, etc.)
  COMPOSITE // Composite product (gift packs, bundles)
}

model Product {
  id              Int         @id @default(autoincrement())
  name            String
  description     String?     @db.Text
  image           String?
  sku             String?     @unique
  barcode         String?
  price           Float // Base price in base currency
  discountedPrice Float? // Discounted price
  cost            Float? // Cost price (purchase price)
  chargeTax       Boolean    @default(false) // Whether to charge tax on this product
  taxPercentage   Float? // Tax percentage to be charged
  discountType    String? // Discount type: "AMOUNT" or "PERCENTAGE"
  discountValue   Float? // Discount value (amount or percentage)
  quantity        Int         @default(0) // Stock quantity
  category        String?
  sub_category    String?
  brand           String?
  productType     ProductType @default(SINGLE) // Product type: single, variant, composite
  variants        Json? // Product variants (stored as JSON) - for VARIANT type
  variantGroups   Json? // Variant groups (e.g., Size: [S, M, L], Color: [Red, Blue])
  compositeItems  Json? // Composite product items (for COMPOSITE type) - array of {productId, quantity, price}
  customFields    Json? // Dynamic custom fields (stored as JSON) - user-defined fields
  status          String      @default("active") // active, inactive, out_of_stock, draft, archived
  companyId       Int?
  branchId        Int?
  createdById     Int? // User who created the product
  updatedById     Int? // User who last updated the product
  company         Company?    @relation("Products", fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch?     @relation("Products", fields: [branchId], references: [id], onDelete: Cascade)
  createdBy       User?       @relation("CreatedProducts", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?       @relation("UpdatedProducts", fields: [updatedById], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  returnedItems   OrderReturnItem[] @relation("ReturnedProducts")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([category])
  @@index([sub_category])
  @@index([createdById])
  @@index([updatedById])
  @@index([productType])
}

model Customer {
  id         Int      @id @default(autoincrement())
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  companyId  Int?
  branchId   Int?
  company    Company? @relation("Customers", fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation("Customers", fields: [branchId], references: [id], onDelete: Cascade)
  orders     Order[]
  payments   CustomerPayment[]
  returns    OrderReturn[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([email])
  @@index([name])
}

model Order {
  id              Int         @id @default(autoincrement())
  orderNumber     String      @unique
  customerId      Int
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          OrderStatus @default(PENDING)
  type            OrderType   @default(SALE)
  totalAmount     Float // Total order amount
  subtotal        Float // Subtotal before tax/discount
  tax             Float?      @default(0)
  discount        Float?      @default(0)
  shippingCost    Float?      @default(0)
  currency        String?     @default("USD")
  paymentMethod   String?
  paymentStatus   String? // paid, pending, failed
  shippingAddress String?
  notes           String?     @db.Text
  orderDate       DateTime    @default(now())
  shippedDate     DateTime?
  deliveredDate   DateTime?
  companyId       Int?
  branchId        Int?
  company         Company?    @relation("Orders", fields: [companyId], references: [id], onDelete: Cascade)
  branch          Branch?     @relation("Orders", fields: [branchId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  payments        CustomerPayment[]
  returns         OrderReturn[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@index([orderNumber])
  @@index([companyId, branchId])
}

model OrderItem {
  id             Int      @id @default(autoincrement())
  orderId        Int
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      Int
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity       Int
  returnedQuantity Int    @default(0) // Quantity returned for this item
  price          Float // Price at time of order
  discount       Float?   @default(0)
  subtotal       Float // quantity * price - discount
  returns        OrderReturnItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

enum FileType {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  ARCHIVE
  OTHER
}

model Folder {
  id             Int      @id @default(autoincrement())
  name           String
  parentFolderId Int?
  parentFolder   Folder?  @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: Cascade)
  subfolders     Folder[] @relation("FolderHierarchy")
  files          File[]
  starred        Boolean  @default(false)
  userId         Int?
  companyId      Int?
  branchId       Int?
  user           User?    @relation("Folders", fields: [userId], references: [id], onDelete: Cascade)
  company        Company? @relation("Folders", fields: [companyId], references: [id], onDelete: Cascade)
  branch         Branch?  @relation("Folders", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([parentFolderId])
  @@index([starred])
}

model File {
  id           Int      @id @default(autoincrement())
  name         String
  originalName String? // Original file name before upload
  type         FileType @default(OTHER)
  mimeType     String? // MIME type (e.g., image/png, application/pdf)
  size         Int // Size in bytes
  url          String? // File storage URL/path
  thumbnailUrl String? // Thumbnail URL for images/videos
  deviceType   String? // Device type: "mobile" or "desktop"
  folderId     Int?
  folder       Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  starred      Boolean  @default(false)
  userId       Int?
  companyId    Int?
  branchId     Int?
  user         User?    @relation("Files", fields: [userId], references: [id], onDelete: Cascade)
  company      Company? @relation("Files", fields: [companyId], references: [id], onDelete: Cascade)
  branch       Branch?  @relation("Files", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([folderId])
  @@index([type])
  @@index([starred])
  @@index([createdAt])
}

enum ProjectStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model Project {
  id            Int             @id @default(autoincrement())
  title         String
  subtitle      String?
  description   String?         @db.Text
  status        ProjectStatus   @default(PENDING)
  progress      Int             @default(0) // 0-100
  startDate     DateTime?
  endDate       DateTime?
  deadline      DateTime?
  budget        Float?
  spent         Float?          @default(0)
  clientName    String?
  clientAvatar  String?
  progressColor String? // For UI display (e.g., "bg-orange-500")
  badgeColor    String? // For UI display (e.g., "bg-orange-500")
  managerId     Int? // Project manager
  manager       User?           @relation("ManagedProjects", fields: [managerId], references: [id], onDelete: SetNull)
  companyId     Int?
  branchId      Int?
  company       Company?        @relation("Projects", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?         @relation("Projects", fields: [branchId], references: [id], onDelete: Cascade)
  members       ProjectMember[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([managerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([deadline])
  @@index([companyId, branchId])
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation("ProjectMembers", fields: [userId], references: [id], onDelete: Cascade)
  role      String? // e.g., "developer", "designer", "tester"
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model MenuItem {
  id          Int        @id @default(autoincrement())
  title       String
  href        String
  icon        String? // Icon name from lucide-react
  group       String? // Menu group (e.g., "Dashboards", "Apps", "AI Apps", "Pages", "Others")
  parentId    Int? // For nested menu items
  parent      MenuItem?  @relation("MenuItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[] @relation("MenuItemChildren")
  order       Int        @default(0) // Order within group or parent
  isActive    Boolean    @default(true)
  isComing    Boolean    @default(false)
  isNew       Boolean    @default(false)
  isDataBadge String? // Badge text (e.g., "8", "5")
  newTab      Boolean    @default(false)
  companyId   Int? // Optional: company-specific menus
  company     Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    Int? // Optional: branch-specific menus
  branch      Branch?    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([group, order])
  @@index([parentId, order])
  @@index([companyId])
  @@index([branchId])
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
}

model Reminder {
  id          Int             @id @default(autoincrement())
  note        String
  priority    ReminderPriority @default(MEDIUM)
  category    String?         // e.g., "Meeting", "Design Education", "Customer Support"
  dueDate     DateTime?       // Date and time for the reminder
  isCompleted Boolean         @default(false)
  userId      Int?            // User who created the reminder
  user        User?           @relation("Reminders", fields: [userId], references: [id], onDelete: Cascade)
  companyId   Int?
  branchId    Int?
  company     Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([isCompleted])
  @@index([dueDate])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHEQUE
  OTHER
}

model CustomerPayment {
  id            Int           @id @default(autoincrement())
  paymentNumber String        @unique
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId       Int?
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  amount        Float
  paymentMethod PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  paymentDate   DateTime      @default(now())
  reference     String?       // Payment reference number
  notes         String?       @db.Text
  companyId     Int?
  branchId      Int?
  company       Company?      @relation("CustomerPayments", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation("CustomerPayments", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([paymentDate])
  @@index([paymentNumber])
  @@index([companyId, branchId])
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId Int?
  branchId  Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ipAddress String?
  latitude  Float?
  longitude Float?
  city      String?
  region    String?
  country   String?
  timezone  String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  loginAt   DateTime @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([loginAt])
  @@index([companyId, branchId])
  @@index([userId, loginAt])
}

model Supplier {
  id         Int      @id @default(autoincrement())
  name       String
  email      String?
  phone      String?
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  companyId  Int?
  branchId   Int?
  company    Company? @relation("Suppliers", fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation("Suppliers", fields: [branchId], references: [id], onDelete: Cascade)
  payments   SupplierPayment[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([email])
  @@index([name])
}

model SupplierPayment {
  id            Int           @id @default(autoincrement())
  paymentNumber String        @unique
  supplierId    Int
  supplier      Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount        Float
  paymentMethod PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  paymentDate   DateTime      @default(now())
  reference     String?       // Payment reference number
  notes         String?       @db.Text
  companyId     Int?
  branchId      Int?
  company       Company?      @relation("SupplierPayments", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation("SupplierPayments", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([paymentDate])
  @@index([paymentNumber])
  @@index([companyId, branchId])
}

// Storage Quota - Track storage limits and usage per company/branch
model StorageQuota {
  id            Int      @id @default(autoincrement())
  companyId     Int?
  branchId      Int?
  company       Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  totalStorage  BigInt   @default(10737418240) // 10 GB default in bytes
  usedStorage   BigInt   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([companyId, branchId])
}

// System Settings - Store various system settings per company/branch
model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   // Setting key (e.g., "autoBackup", "backupFrequency")
  value       String   @db.Text // JSON string or plain value
  companyId   Int?
  branchId    Int?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([key])
  @@index([companyId, branchId])
}

// Exception Log - Store application exceptions and errors
model ExceptionLog {
  id          Int      @id @default(autoincrement())
  type        String   // Exception type/name
  severity    String   // low, medium, high, critical
  message     String   @db.Text
  stack       String?  @db.Text // Stack trace
  source      String   // Source component (e.g., "FileManager", "Database", "Auth")
  userId      Int?
  user        User?    @relation("ExceptionLogs", fields: [userId], references: [id], onDelete: SetNull)
  companyId   Int?
  branchId    Int?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requestUrl  String?  // Request URL if applicable
  requestMethod String? // HTTP method
  userAgent   String?  @db.Text
  ipAddress   String?
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  resolvedBy  Int?     // User ID who resolved it
  notes       String?  @db.Text
  metadata    Json?    // Additional metadata as JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([userId])
  @@index([severity])
  @@index([resolved])
  @@index([source])
  @@index([createdAt])
  @@index([companyId, branchId])
  @@index([severity, resolved])
}

enum ReturnStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum ReturnReason {
  DEFECTIVE
  DAMAGED
  WRONG_ITEM
  NOT_AS_DESCRIBED
  CUSTOMER_CHANGE_MIND
  LATE_DELIVERY
  DUPLICATE_ORDER
  OTHER
}

enum RefundMethod {
  ORIGINAL_PAYMENT
  CASH
  CARD
  BANK_TRANSFER
  STORE_CREDIT
  EXCHANGE
}

model OrderReturn {
  id                Int                 @id @default(autoincrement())
  returnNumber      String              @unique
  orderId           Int
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId        Int
  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status            ReturnStatus        @default(PENDING)
  returnReason      ReturnReason
  returnReasonNote  String?             @db.Text
  returnDate        DateTime            @default(now())
  processedDate     DateTime?
  refundAmount      Float               @default(0)
  refundMethod      RefundMethod?
  refundStatus      PaymentStatus?      @default(PENDING)
  refundReference   String?              // Reference number for refund transaction
  items             OrderReturnItem[]
  notes             String?              @db.Text
  processedById     Int?                // User who processed the return
  processedBy        User?               @relation("ProcessedReturns", fields: [processedById], references: [id], onDelete: SetNull)
  companyId         Int?
  branchId          Int?
  company           Company?            @relation("OrderReturns", fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?              @relation("OrderReturns", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([returnDate])
  @@index([returnNumber])
  @@index([processedById])
  @@index([companyId, branchId])
}

model OrderReturnItem {
  id              Int         @id @default(autoincrement())
  returnId        Int
  return          OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItemId     Int
  orderItem       OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product     @relation("ReturnedProducts", fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int         // Quantity being returned
  price            Float       // Price at time of return (from original order)
  refundAmount     Float       // Refund amount for this item
  reason           ReturnReason?
  reasonNote       String?     @db.Text
  condition        String?     // Condition of returned item (new, used, damaged, etc.)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([returnId])
  @@index([orderItemId])
  @@index([productId])
}

enum TableStatus {
  available
  occupied
  reserved
}

model TableCategory {
  id        Int      @id @default(autoincrement())
  name      String
  companyId Int?
  branchId  Int?
  company   Company? @relation("TableCategories", fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation("TableCategories", fields: [branchId], references: [id], onDelete: Cascade)
  tables    Table[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([companyId, branchId])
}

model Table {
  id         Int          @id @default(autoincrement())
  name       String
  status     TableStatus  @default(available)
  categoryId Int
  category   TableCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  companyId  Int?
  branchId   Int?
  company    Company?     @relation("Tables", fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?      @relation("Tables", fields: [branchId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([categoryId])
  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([companyId, branchId])
}

model ReportTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  entityType  String   // Entity type this report is for (LEAD, DEAL, CUSTOMER, ORDER, etc.)
  columns     Json     // Array of column configurations: { field: string, label: string, visible: boolean, order: number }
  filters     Json?    // Filter configurations
  sorting     Json?    // Default sorting configuration
  companyId   Int?
  branchId    Int?
  company     Company? @relation("ReportTemplates", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation("ReportTemplates", fields: [branchId], references: [id], onDelete: Cascade)
  createdById Int?
  updatedById Int?
  createdBy   User?    @relation("CreatedReportTemplates", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("UpdatedReportTemplates", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([entityType])
  @@index([companyId, branchId])
}

model PdfReport {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  entityType  String?  // Optional entity type this report is for
  layout      Json     // Array of report elements: { id, type, position, config, etc. }
  pageSettings Json    // Page configuration: { size: "A4", orientation: "portrait", margins: {...} }
  isActive    Boolean  @default(true)
  companyId   Int?
  branchId    Int?
  company     Company? @relation("PdfReports", fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation("PdfReports", fields: [branchId], references: [id], onDelete: Cascade)
  createdById Int?
  updatedById Int?
  createdBy   User?    @relation("CreatedPdfReports", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("UpdatedPdfReports", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([entityType])
  @@index([isActive])
  @@index([companyId, branchId])
}

model DealDashboard {
  id          Int                 @id @default(autoincrement())
  name        String
  description String?

  // What to show
  filter      Json                // saved search/filter definition
  layout      Json                // UI layout (cards/widgets arrangement)
  widgets     Json                // widget definitions (counts/charts etc.)

  // Who can see it
  visibility  DashboardVisibility @default(PRIVATE)

  companyId   Int
  branchId    Int?
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?             @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdById Int
  createdBy   User                @relation("CreatedDealDashboards", fields: [createdById], references: [id], onDelete: Cascade)

  roleShares  DealDashboardRoleShare[]
  userShares  DealDashboardUserShare[]
  userPrefs   DealDashboardUserPref[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([createdById])
  @@index([visibility])
}

model DealDashboardRoleShare {
  id          Int           @id @default(autoincrement())
  dashboardId Int
  roleId      Int

  dashboard   DealDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  role        Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())

  @@unique([dashboardId, roleId])
  @@index([dashboardId])
  @@index([roleId])
}

model DealDashboardUserShare {
  id          Int           @id @default(autoincrement())
  dashboardId Int
  userId      Int

  dashboard   DealDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())

  @@unique([dashboardId, userId])
  @@index([dashboardId])
  @@index([userId])
}

model DealDashboardUserPref {
  id          Int           @id @default(autoincrement())
  dashboardId Int
  userId      Int

  // Per-user library ordering and display state
  order       Int           @default(0)
  isPinned    Boolean       @default(false)
  isCollapsed Boolean       @default(false)

  dashboard   DealDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([dashboardId])
  @@unique([dashboardId, userId])
}
