model SmtpSetting {
  id        Int      @id @default(autoincrement())
  name      String // Configuration name
  host      String // SMTP server host
  port      Int // SMTP port (e.g., 587, 465, 25)
  secure    Boolean  @default(false) // Use SSL/TLS
  username  String // SMTP username/email
  password  String // SMTP password (encrypted)
  fromEmail String // Default from email address
  fromName  String? // Default from name
  isActive  Boolean  @default(false) // Whether this is the active SMTP configuration
  isDefault Boolean  @default(false) // Whether this is the default configuration
  companyId Int?
  branchId  Int?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  mails     Mail[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, companyId, branchId])
  @@index([companyId])
  @@index([branchId])
  @@index([isActive])
  @@index([isDefault])
  @@index([companyId, branchId])
}

model Mail {
  id            Int          @id @default(autoincrement())
  subject       String
  body          String // Email body (text or HTML)
  fromEmail     String // Sender email address
  fromName      String? // Sender name
  toEmail       String // Recipient email address
  toName        String? // Recipient name
  cc            String? // CC recipients (comma-separated)
  bcc           String? // BCC recipients (comma-separated)
  replyTo       String? // Reply-to email address
  folder        MailFolder   @default(INBOX) // Folder: INBOX, SENT, DRAFT, TRASH, ARCHIVE
  isRead        Boolean      @default(false)
  isStarred     Boolean      @default(false)
  isImportant   Boolean      @default(false)
  labels        String[]     @default([]) // Array of label strings
  attachments   Json? // Array of attachment objects
  headers       Json? // Email headers (JSON object)
  sentAt        DateTime? // When email was sent (null for drafts)
  receivedAt    DateTime? // When email was received (null for sent/drafts)
  userId        Int // User who owns this mail
  user          User         @relation("UserMails", fields: [userId], references: [id], onDelete: Cascade)
  companyId     Int?
  branchId      Int?
  company       Company?     @relation("CompanyMails", fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch?      @relation("BranchMails", fields: [branchId], references: [id], onDelete: Cascade)
  smtpSettingId Int? // SMTP setting used to send this email
  smtpSetting   SmtpSetting? @relation(fields: [smtpSettingId], references: [id], onDelete: SetNull)
  threadId      String? // Thread ID for grouping related emails
  inReplyTo     Int? // ID of email this is a reply to
  parentMail    Mail?        @relation("MailReplies", fields: [inReplyTo], references: [id], onDelete: SetNull)
  replies       Mail[]       @relation("MailReplies")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([branchId])
  @@index([folder])
  @@index([isRead])
  @@index([isStarred])
  @@index([sentAt])
  @@index([receivedAt])
  @@index([threadId])
  @@index([userId, folder])
  @@index([companyId, branchId])
}

enum MailFolder {
  INBOX
  SENT
  DRAFT
  TRASH
  ARCHIVE
  SPAM
}

