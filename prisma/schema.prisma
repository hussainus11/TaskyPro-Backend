enum Module {
  LEADS
  CONTACTS
  DEALS
  COMPANIES
  TASKS
  DOCUMENTS
  INVOICES
  ESTIMATES
  REPORTS
  SETTINGS
  USERS
  PRODUCTS
  ORDERS
  DASHBOARD
  ANALYTICS
  EMAIL
  INTEGRATIONS
  AUTOMATION
}

enum ResourceType {
  MENU
  PAGE
  SECTION
  FIELD
}

model PermissionSetting {
  id                 Int                 @id @default(autoincrement())
  roleId             Int // Role this permission applies to
  role               Role                @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module             Module? // Module this permission is for (kept for backward compatibility)
  resourceType       ResourceType?       @default(MENU) // Type of resource: MENU, PAGE, SECTION, FIELD
  resourcePath       String? // Hierarchical path like "crm" or "crm.leads" or "crm.leads.create"
  resourceName       String? // Human-readable resource name
  parentId           Int? // Parent permission setting ID for hierarchy
  parent             PermissionSetting?  @relation("PermissionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children           PermissionSetting[] @relation("PermissionHierarchy")
  canRead            Boolean             @default(false)
  canWrite           Boolean             @default(false) // create / add
  canEdit            Boolean             @default(false) // update / edit (separate from add)
  canDelete          Boolean             @default(false)
  canManage          Boolean             @default(false) // Full management access
  canExport          Boolean             @default(false)
  canImport          Boolean             @default(false)
  fieldPermissions   Json? // Field-level permissions stored as JSON: { "fieldName": { "canRead": true, "canWrite": false } }
  sectionPermissions Json? // Section-level permissions stored as JSON
  companyId          Int?
  branchId           Int?
  company            Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch             Branch?             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([roleId, module, companyId, branchId])
  @@unique([roleId, resourcePath, companyId, branchId])
  @@index([roleId])
  @@index([module])
  @@index([resourceType])
  @@index([resourcePath])
  @@index([parentId])
  @@index([companyId, branchId])
  @@index([companyId])
  @@index([branchId])
}

enum ProcessTrigger {
  MANUAL
  SCHEDULED
  EVENT_BASED
  WEBHOOK
  API_CALL
}

enum ProcessStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum StepType {
  CONDITION
  ACTION
  DELAY
  NOTIFICATION
  ASSIGNMENT
  UPDATE_FIELD
  CREATE_RECORD
  SEND_EMAIL
  WEBHOOK
}

model BusinessProcess {
  id            Int            @id @default(autoincrement())
  name          String // Process name
  description   String? // Process description
